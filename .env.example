# =============================================================================
# Polymarket BTC 5min / 15min Arbitrage Bot — environment template
# =============================================================================
# SEO / discovery: polymarket trading bot, polymarket arbitrage bot,
# polymarket BTC bot, polymarket 5 minute market bot, polymarket CLOB bot
#
# Copy to ".env" and fill in values. Never commit .env or share private keys.
# =============================================================================

# --- Required: wallet that signs Polymarket CLOB requests (L1 / L2) ----------
# Polygon-compatible private key (0x-prefixed hex). Used with ethers + clob-client-v2.
POLYMARKET_PRIVATE_KEY=

# --- Required: funded / proxy (deposit) address -------------------------------
# The address that holds USDC collateral for trading on Polymarket (often ≠ signer for proxy setups).
POLYMARKET_FUNDER_ADDRESS=

# Alternative variable name accepted by the loader (if FUNDER line above is empty):
# PROXY_WALLET_ADDRESS=

# --- Optional: signature type -------------------------------------------------
# EOA | POLY_PROXY | POLY_GNOSIS_SAFE | POLY_1271
# Leave unset to use default proxy-oriented behavior, or set explicitly to match your account.
# POLYMARKET_SIGNATURE_TYPE=POLY_PROXY

# --- Notes --------------------------------------------------------------------
# - Pair this file with trade.toml: market_period "5" or "15" for short BTC windows.
# - Docs: see README.md — Quick start, Environment variables, Troubleshooting.
