# ── Required ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
MARKET_ID_5M=0xYOUR_5MIN_MARKET_CONDITION_ID
MARKET_ID_15M=0xYOUR_15MIN_MARKET_CONDITION_ID

# ── Strategy ──────────────────────────────────────────────────────────────────
# Execute when combined leg cost is AT OR BELOW this value
# 0.97 = requires at least 3 cents profit per $1 payout
ARB_THRESHOLD=0.97
DEFAULT_SIZE=50
MAX_DAILY_TRADES=20

# ── Risk ──────────────────────────────────────────────────────────────────────
MAX_EXPOSURE_USD=1000

# ── Timing ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000
STALE_DATA_MAX_AGE_MS=10000

# ── Auto-redeem settled positions ─────────────────────────────────────────────
AUTO_REDEEM_ENABLED=true
REDEEM_THRESHOLD_USD=1.0

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# POLYMARKET_API_URL=https://clob.polymarket.com
# ENVIRONMENT=production
